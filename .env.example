# Copie para .env e ajuste. .env é ignorado pelo git.

# API do ecomm-data (../ecomm-data), acessível a partir do container do meltano.
# Com os dois projetos no mesmo docker compose e na rede "cdp-shared-net"
# (ver README), use o nome do serviço. Rodando o meltano direto no host, use
# http://localhost:3000.
ECOMM_DATA_API_URL=http://ecomm-data:3000

# Export do GA4 lido dos arquivos locais por scripts/load_ga4_customer_behavior.py.
GA4_SOURCE_GLOB=/ga4_source/events/events_*.json.gz
# Opcional: limita quantos dias processar (vazio = todos).
MAX_DAYS=

# Warehouse ClickHouse (serviço "clickhouse" no docker-compose.yml).
# CLICKHOUSE_PASSWORD não pode ficar vazio: o driver HTTP usado pelo
# target-clickhouse e pelo dbt-clickhouse manda Basic Auth com a senha, e o
# ClickHouse rejeita Basic Auth com senha vazia (mesmo pro usuário "default"
# sem senha configurada) — defina qualquer valor não-vazio.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=raw
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_local_dev
